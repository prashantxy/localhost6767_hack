{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "memorylen",
  "version": "0.1.0",
  "identifier": "com.memorylen.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MemoryLens",
        "width": 680,
        "height": 550,
        "center": true,

        "visible": true,

        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,

        "skipTaskbar": true,
        "shadow": false,

        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,

        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}