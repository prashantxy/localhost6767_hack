{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",

    "window:allow-show",
    "window:allow-hide",
    "window:allow-set-focus"
  ]
}